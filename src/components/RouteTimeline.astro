---
/**
 * RouteTimeline (§9, signature §10) — фирменный блок ТОЛЬКО маршрутов.
 *
 * Вертикальная пунктирная «дорога» с остановками из frontmatter `stops[]`
 * (§11) плюс сводка сверху: всего км (`distanceKm`), дней (`days`), бюджет от
 * (`budgetFrom`) и (опц.) лучший сезон (`bestSeason`).
 *
 * Реализация — преимущественно CSS, НОЛЬ JS:
 *  - «дорога» — вертикальная линия с `border-left: dashed` (пунктир = бордюр,
 *    не картинка) у списка остановок;
 *  - маркеры-точки — псевдоэлемент `::before` каждого пункта (кружок-вино);
 *  - данные строго из пропсов (frontmatter), а не из текста (§8.2).
 *
 * Доступность (§15): остановки — семантический `<ol>` (порядок важен),
 * иконки — SVG (currentColor), контраст из токенов. `prefers-reduced-motion`:
 * у пунктира и маркеров нет анимаций по умолчанию; единственный мягкий reveal
 * наследуется от глобального слоя движения, который сам глушится при reduce
 * (global.css). Хардкода hex нет — только var(--…).
 */
import { t, format, monthName, type Lang } from '../i18n';
import Icon from './Icon.astro';
import type { IconName } from './iconNames';

export interface RouteStop {
  name: string;
  km: number;
  stayMin?: number;
  note?: string;
  /** Фото остановки (§8.2): миниатюра + CC-кредит. Опционально. */
  photo?: { src: string; alt: string; credit?: string };
}

interface Props {
  lang: Lang;
  days: number;
  distanceKm: number;
  budgetFrom: { amount: number; currency: string };
  /** Слаги месяцев из `bestSeason` (§11); пусто — блок сезона не рисуется. */
  bestSeason?: string[];
  stops: RouteStop[];
}

const { lang, days, distanceKm, budgetFrom, bestSeason = [], stops } = Astro.props;
const dict = t(lang);
const r = dict.route;

/** Бюджет «от» — число + валюта из frontmatter (никаких выдуманных цифр). */
const budgetLabel = `${budgetFrom.amount} ${budgetFrom.currency}`;

/** Локализованный список сезона из слагов месяцев (§11 → §12). */
const seasonLabel = bestSeason.map((m) => monthName(lang, m)).join(', ');

/** Метрики сводки. Значения — строго из пропсов (frontmatter, §8.2). */
const metrics: { icon: IconName; label: string; value: string }[] = [
  {
    icon: 'calendar',
    label: r.summary.days,
    value: format(r.summary.daysValue, { count: String(days) }),
  },
  {
    icon: 'milestone',
    label: r.summary.distance,
    value: format(r.summary.distanceValue, { km: String(distanceKm) }),
  },
  { icon: 'coins', label: r.summary.budget, value: budgetLabel },
];
if (seasonLabel) {
  metrics.push({ icon: 'calendar', label: r.summary.season, value: seasonLabel });
}

const lastIndex = stops.length - 1;
---

<section class="rt" aria-labelledby="rt-heading" data-reveal>
  <h2 id="rt-heading" class="rt__heading">{r.timelineHeading}</h2>

  {/* Сводка маршрута: дни / км / бюджет / сезон — из frontmatter. */}
  <dl class="rt__summary">
    {
      metrics.map((m) => (
        <div class="rt__metric">
          <span class="rt__metric-icon">
            <Icon name={m.icon} size={20} />
          </span>
          <div class="rt__metric-body">
            <dt class="rt__metric-label">{m.label}</dt>
            <dd class="rt__metric-value">{m.value}</dd>
          </div>
        </div>
      ))
    }
  </dl>

  {/* Пунктирная «дорога» с остановками — фирменный элемент маршрутов (§10). */}
  {
    stops.length > 0 && (
      <ol class="rt__road" aria-label={r.timelineAria}>
        {stops.map((stop, i) => (
          <li
            class="rt__stop"
            data-first={i === 0 ? '' : undefined}
            data-last={i === lastIndex ? '' : undefined}
          >
            <div class="rt__stop-head">
              <h3 class="rt__stop-name">{stop.name}</h3>
              <span class="rt__stop-km">
                {i === 0 ? r.stopStart : format(r.stopKm, { km: String(stop.km) })}
              </span>
            </div>
            {stop.stayMin != null && (
              <p class="rt__stop-stay">
                <Icon name="clock" size={15} class="rt__stop-stay-icon" />
                <span>{format(r.stopStay, { min: String(stop.stayMin) })}</span>
              </p>
            )}
            {stop.note && <p class="rt__stop-note">{stop.note}</p>}
            {stop.photo && (
              <figure class="rt__stop-photo">
                <img
                  src={stop.photo.src}
                  alt={stop.photo.alt}
                  width="640"
                  height="360"
                  loading="lazy"
                  decoding="async"
                />
                {stop.photo.credit && (
                  <figcaption class="rt__stop-credit">{stop.photo.credit}</figcaption>
                )}
              </figure>
            )}
          </li>
        ))}
      </ol>
    )
  }
</section>

<style>
  .rt {
    margin-block: var(--space-8) var(--space-12);
    max-width: var(--container-prose);
  }
  .rt__heading {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-6);
  }

  /* --- Сводка: компактные плитки-метрики --- */
  .rt__summary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin: 0 0 var(--space-8);
  }
  @media (min-width: 560px) {
    .rt__summary {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .rt__metric {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--surface-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-card);
  }
  .rt__metric-icon {
    display: inline-flex;
    color: var(--color-wine);
    flex: none;
    margin-top: 2px;
  }
  .rt__metric-body {
    min-width: 0;
  }
  .rt__metric-label {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.3;
  }
  .rt__metric-value {
    margin: var(--space-1) 0 0;
    font-weight: 600;
    color: var(--text-body);
    line-height: 1.3;
  }

  /*
   * --- Пунктирная «дорога» (signature §10) ---
   * Линия = левый пунктирный бордюр <ol>. Каждая остановка — кружок-маркер
   * (::before), посаженный точно на линию. Пунктир — чистый CSS (border-style:
   * dashed), без картинок и без JS.
   */
  .rt__road {
    list-style: none;
    margin: 0;
    padding: 0;
    /* отступ слева под «дорогу» и маркеры */
    padding-inline-start: var(--space-6);
    /* сама дорога — пунктирная линия вином на низкой альфе */
    border-inline-start: 2px dashed var(--border-wine);
  }
  .rt__stop {
    position: relative;
    padding-block: 0 var(--space-8);
  }
  .rt__stop[data-last] {
    padding-bottom: 0;
  }
  /* Маркер-точка остановки на линии. */
  .rt__stop::before {
    content: '';
    position: absolute;
    top: 4px;
    /* центрируем кружок ровно на пунктирной линии (учёт ширины бордюра 2px) */
    inset-inline-start: calc(-1 * var(--space-6) - 7px);
    width: 12px;
    height: 12px;
    border-radius: var(--radius-pill);
    background: var(--surface-card);
    border: 3px solid var(--color-wine);
    box-sizing: border-box;
  }
  /* Старт и финиш — залитые маркеры (флажки маршрута, акцент). */
  .rt__stop[data-first]::before,
  .rt__stop[data-last]::before {
    background: var(--color-wine);
  }

  .rt__stop-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-3);
  }
  .rt__stop-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lg);
    color: var(--text-heading);
    margin: 0;
    line-height: 1.2;
  }
  .rt__stop-km {
    font-size: var(--text-sm);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .rt__stop-stay {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-2) 0 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .rt__stop-stay-icon {
    color: var(--color-wine);
    flex: none;
  }
  .rt__stop-note {
    margin: var(--space-2) 0 0;
    font-size: var(--text-base);
    color: var(--text-body);
    max-width: 60ch;
  }
  /*
   * Миниатюра остановки (§8.2): фикс. аспект 16:9 (width/height + aspect-ratio)
   * → 0 CLS (§15); object-fit cover аккуратно кадрирует переиспользованное фото.
   * Кредит CC — мелкой приглушённой подписью (§18).
   */
  .rt__stop-photo {
    margin: var(--space-3) 0 0;
    max-width: 420px;
  }
  .rt__stop-photo img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-card);
    border: 1px solid var(--border-card);
    background: var(--surface-card);
  }
  .rt__stop-credit {
    margin: var(--space-1) 0 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    opacity: 0.8;
  }

  /*
   * reduced-motion (§15): у пунктира/маркеров нет собственных анимаций.
   * Глобальный reveal-слой глушится в global.css при reduce; здесь страхуемся,
   * чтобы блок был статичен и сразу видим при любой деградации.
   */
  @media (prefers-reduced-motion: reduce) {
    .rt {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
