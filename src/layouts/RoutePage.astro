---
/**
 * RoutePage (§8.2) — шаблон маршрута.
 * Рендерится из записи коллекции `routes` (§11). Один компонент для ru и uk;
 * язык и запись приходят пропсами, UI-строки — из словарей (§12).
 *
 * Состав (§8.2): всё из шаблона статьи (Breadcrumbs → H1 → VerifiedBadge → лид)
 * + RouteTimeline СРАЗУ после лида (фирменный блок маршрутов) → MapEmbed (lazy)
 * → тело Markdown → AboutNote → AffiliateBox-слот «авто под этот
 * маршрут» (trip-carhire + trip-hotels, §16).
 *
 * Данные маршрута (дни/км/бюджет/остановки) — из frontmatter, НЕ из текста
 * (§8.2). VerifiedBadge (v3.2): «Проверено · {verifiedAt}» только при реальной
 * проверке; для демо verifiedAt не задан → «Обновлено · {updatedAt}».
 *
 * Schema.org (§14): Article + BreadcrumbList (Breadcrumbs)
 * + TouristTrip с itinerary из stops (валидный список TouristAttraction).
 * canonical и взаимные hreflang ru↔uk — в BaseLayout (зеркальная структура §7).
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { t, formatDate, sectionHref, type Lang, type SectionKey } from '../i18n';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import VerifiedBadge from '../components/VerifiedBadge.astro';
import RouteTimeline from '../components/RouteTimeline.astro';
import MapEmbed from '../components/MapEmbed.astro';
import routeGeometry from '../data/route-geometry.json';
import AboutNote from '../components/AboutNote.astro';
import AffiliateBox from '../components/AffiliateBox.astro';
import Icon from '../components/Icon.astro';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'routes'>;
  /** Языки, на которых есть этот маршрут (slug) — для hreflang (§12), из getStaticPaths. */
  availableLangs?: Lang[];
}
const { lang, entry, availableLangs = ['ru', 'uk'] } = Astro.props;
const dict = t(lang);
const data = entry.data;
/** Реальная дорожная геометрия маршрута (запечена на сборке, §8.2); нет — фолбэк на прямые. */
const routeLine = (routeGeometry as unknown as Record<string, [number, number][]>)[data.slug];

const { Content } = await render(entry);

/** Дата бейджа: проверка честная — verifiedAt только при реальной проверке (§14). */
const isVerified = Boolean(data.verifiedAt);
const badgeDate = formatDate(data.verifiedAt ?? data.updatedAt, lang);

const categoryHeading = dict.nav['marshruty'];
const categoryHref = sectionHref(lang, 'marshruty' as SectionKey);

const SITE = Astro.site ?? new URL('https://georgiaguidebook.com');
const pageUrl = new URL(Astro.url.pathname, SITE).href;
const coverUrl = new URL(data.cover.src, SITE).href;

/** JSON-LD Article (§14). publisher — Organization сайта. */
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  image: coverUrl,
  inLanguage: lang,
  datePublished: data.publishedAt.toISOString(),
  dateModified: data.updatedAt.toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  /** author/publisher по @id site-wide Organization (BaseLayout) — единый граф, без author Article не проходит Rich Results. */
  author: { '@type': 'Organization', '@id': `${SITE.href}#organization` },
  publisher: { '@id': `${SITE.href}#organization` },
};

/**
 * JSON-LD TouristTrip (§14) — itinerary из stops (валидный ItemList
 * TouristAttraction с гео). Только при наличии остановок; данные строго из
 * frontmatter (§8.2).
 */
const tripLd =
  data.stops.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'TouristTrip',
        name: data.title,
        description: data.description,
        inLanguage: lang,
        url: pageUrl,
        itinerary: {
          '@type': 'ItemList',
          numberOfItems: data.stops.length,
          itemListElement: data.stops.map((stop, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            item: {
              '@type': 'TouristAttraction',
              name: stop.name,
              geo: {
                '@type': 'GeoCoordinates',
                latitude: stop.coord[0],
                longitude: stop.coord[1],
              },
            },
          })),
        },
        offers: {
          '@type': 'Offer',
          price: data.budgetFrom.amount,
          priceCurrency: data.budgetFrom.currency,
        },
      }
    : null;
---

<BaseLayout
  title={`${data.title} — ${dict.siteName}`}
  description={data.description}
  lang={lang}
  availableLangs={availableLangs}
  image={data.cover.src}
  ogType="article"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  {tripLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(tripLd)} />}

  <article class="route">
    <div class="container">
      <Breadcrumbs
        lang={lang}
        items={[{ label: categoryHeading, href: categoryHref }, { label: data.title }]}
      />

      <header class="head" data-reveal>
        <h1 class="head__title">{data.title}</h1>
        <div class="head__badge">
          <VerifiedBadge
            lang={lang}
            date={badgeDate}
            variant={isVerified ? 'verified' : 'updated'}
            photo={data.verifiedPhoto}
            withCaption={isVerified}
          />
        </div>
        <p class="head__lead">{data.description}</p>
      </header>

      {
        /* Демо-дисклеймер (R3, CLAUDE правило 4): про цифры маршрута именно. */
        data.demo && (
          <aside class="demo-note" role="note" data-reveal>
            <Icon name="route" size={20} class="demo-note__icon" />
            <div>
              <p class="demo-note__heading">{dict.article.demoNoteHeading}</p>
              <p class="demo-note__text">{dict.route.demoNote}</p>
            </div>
          </aside>
        )
      }

      {/* Тело маршрута (проза) — ВЫШЕ таймлайна: сначала объяснение сути кольца,
         затем таймлайн+карта как «обзор остановок» (аудит 2026-06-20). */}
      <div class="prose" data-reveal>
        <Content />
      </div>

      {/* RouteTimeline — обзор остановок (§8.2). Данные из frontmatter. */}
      <RouteTimeline
        lang={lang}
        days={data.days}
        distanceKm={data.distanceKm}
        budgetFrom={data.budgetFrom}
        bestSeason={data.bestSeason}
        stops={data.stops}
      />

      {/* Карта остановок — строго lazy (§8.2). variant="route" → линия между стопами. */}
      <MapEmbed lang={lang} stops={data.stops} variant="route" geometry={routeLine} />

      <AboutNote lang={lang} />

      {
        /* AffiliateBox «авто под этот маршрут» (§8.2, §16). partner=trip-carhire,
           slug=route slug для SubID атрибуции. Один виджет на страницу (CLAUDE правило 2). */
      }
      <div class="aff-route" data-reveal>
        <AffiliateBox
          lang={lang}
          partner="trip-carhire"
          slug={data.slug}
          title={dict.route.affiliateHeading}
          label={dict.actions.more}
          note={dict.route.affiliateNote}
        />
        {/* Многодневный маршрут = ночёвки по пути → бокс жилья (§16, 1–3 бокса на стр.). */}
        <AffiliateBox
          lang={lang}
          partner="trip-hotels"
          slug={data.slug}
          title={dict.route.affiliateHotelsHeading}
          label={dict.actions.more}
          note={dict.route.affiliateHotelsNote}
        />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-content);
    margin: 0 auto;
    padding-inline: var(--space-4);
  }
  .route {
    padding-block: var(--space-8) var(--space-12);
  }

  .head {
    margin-bottom: var(--space-8);
    max-width: var(--container-prose);
  }
  .head__title {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-4);
  }
  @media (min-width: 768px) {
    .head__title {
      font-size: var(--text-4xl);
    }
  }
  .head__badge {
    margin-bottom: var(--space-6);
  }
  .head__lead {
    margin: 0;
    font-size: var(--text-xl);
    color: var(--text-body);
  }

  /* Демо-дисклеймер */
  .demo-note {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    margin-bottom: var(--space-8);
    max-width: var(--container-prose);
    background: var(--surface-card);
    border: 1px dashed var(--border-card);
    border-radius: var(--radius-card);
  }
  .demo-note__icon {
    color: var(--color-wine);
    flex: none;
    margin-top: 2px;
  }
  .demo-note__heading {
    margin: 0 0 var(--space-1);
    font-weight: 600;
    color: var(--text-body);
  }
  .demo-note__text {
    margin: 0;
    font-size: var(--text-base);
    color: var(--text-muted);
  }

  /* Проза маршрута — та же узкая колонка, что у статьи (§10). */
  .prose {
    max-width: var(--container-prose);
    font-size: var(--text-lg);
    color: var(--text-body);
  }
  .prose :global(h2) {
    font-size: var(--text-2xl);
    margin: var(--space-12) 0 var(--space-4);
    scroll-margin-top: var(--space-16);
  }
  .prose :global(h3) {
    font-size: var(--text-xl);
    margin: var(--space-8) 0 var(--space-3);
    scroll-margin-top: var(--space-16);
  }
  .prose :global(p) {
    margin: 0 0 var(--space-4);
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-4);
    padding-inline-start: var(--space-6);
  }
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
  .prose :global(li)::marker {
    color: var(--color-wine);
  }
  .prose :global(a) {
    color: var(--link);
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    color: var(--link-hover);
  }
  .prose :global(strong) {
    color: var(--text-body);
  }

  /*
   * Инлайн-фигуры в теле маршрута (§8.1/§8.2) — фото с подписью «что на фото» и
   * CC-кредитом. width/height в разметке → зарезервированный аспект, 0 CLS (§15).
   */
  .prose :global(figure.figure) {
    margin: var(--space-8) 0;
  }
  .prose :global(figure.figure img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    background: var(--surface-card);
    border: 1px solid var(--border-card);
  }
  .prose :global(figure.figure figcaption) {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--text-muted);
  }
  .prose :global(figure.figure .figure__credit) {
    display: block;
    margin-top: 2px;
    opacity: 0.8;
  }

  /* Обёртка AffiliateBox на странице маршрута (§8.2, §16). */
  .aff-route {
    display: grid;
    gap: var(--space-4);
    margin-block: var(--space-12);
    max-width: var(--container-prose);
  }
</style>
