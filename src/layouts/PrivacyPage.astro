---
/**
 * PrivacyPage (§18) — «Политика конфиденциальности и cookies». Раскрывает, какие
 * данные собирает статический сайт (только GA4 через Consent Mode v2 — после
 * согласия), какие cookies, дисклеймер партнёрских ссылок, сторонние сервисы и
 * права пользователя. Обычная индексируемая страница (рекламные сети требуют
 * доступной политики) с canonical + взаимными hreflang. Один компонент на язык,
 * текст — из словарей (§12). Реального юрлица/адреса не выдумываем (CLAUDE правило 4):
 * контакт — почта сайта из словаря contacts.channels.
 *
 * Schema.org (§14): WebPage с publisher-Organization — здесь; BreadcrumbList —
 * в Breadcrumbs. canonical и взаимные hreflang — в BaseLayout (§7, §12).
 */
import { t, formatDate, type Lang } from '../i18n';
import { clampDesc } from '../lib/text';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = t(lang);
const privacy = dict.privacy;
const contacts = dict.contacts;

const pageTitle = `${privacy.heading} — ${dict.siteName}`;
const description = clampDesc(privacy.intro[0]);
const updatedDate = formatDate(new Date(`${privacy.updatedIso}T00:00:00Z`), lang);

const SITE = Astro.site ?? new URL('https://montenegroguidebook.com');
const pageUrl = new URL(Astro.url.pathname, SITE).href;

/**
 * JSON-LD WebPage о политике + издатель Organization (§14). Без выдуманных
 * цифр/юрлица (правило 4) — только тип страницы и язык.
 */
const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: privacy.heading,
  description,
  url: pageUrl,
  inLanguage: lang,
  isPartOf: { '@id': `${SITE.href}#website` },
  publisher: { '@id': `${SITE.href}#organization` },
};
---

<BaseLayout title={pageTitle} description={description} lang={lang}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageLd)} />

  <article class="privacy">
    <div class="container">
      <Breadcrumbs lang={lang} items={[{ label: privacy.breadcrumb }]} />

      <header class="head" data-reveal>
        <h1 class="head__title">{privacy.heading}</h1>
        <p class="head__updated">{privacy.updatedLabel} · {updatedDate}</p>
        <div class="head__intro">
          {privacy.intro.map((p: string) => <p>{p}</p>)}
        </div>
      </header>

      <div class="sections">
        {
          privacy.sections.map((section) => (
            <section class="section" data-reveal>
              <h2 class="section__heading">{section.heading}</h2>
              {section.paragraphs.map((p: string) => (
                <p class="section__text">{p}</p>
              ))}
            </section>
          ))
        }
      </div>

      {/* Контакт по вопросам приватности — почта сайта из словаря (без выдуманного юрлица). */}
      <aside class="contact" aria-labelledby="privacy-contact-heading" data-reveal>
        <span class="contact__icon">
          <Icon name="mail" size={24} />
        </span>
        <div class="contact__body">
          <h2 id="privacy-contact-heading" class="contact__heading">{contacts.channels.heading}</h2>
          <p class="contact__line">
            {privacy.contactLabel}{' '}
            <a class="contact__link u-underline" href={contacts.channels.emailUrl}>
              {contacts.channels.email}
            </a>
          </p>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-content);
    margin: 0 auto;
    padding-inline: var(--space-4);
  }
  .privacy {
    padding-block: var(--space-8) var(--space-12);
  }
  .head {
    margin-bottom: var(--space-12);
    max-width: var(--container-prose);
  }
  .head__title {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-3);
  }
  @media (min-width: 768px) {
    .head__title {
      font-size: var(--text-4xl);
    }
  }
  .head__updated {
    margin: 0 0 var(--space-6);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
  .head__intro {
    display: grid;
    gap: var(--space-4);
  }
  .head__intro :global(p) {
    margin: 0;
    font-size: var(--text-xl);
    color: var(--text-body);
  }
  .sections {
    display: grid;
    gap: var(--space-12);
    max-width: var(--container-prose);
  }
  .section__heading {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-4);
  }
  .section__text {
    margin: 0 0 var(--space-4);
    font-size: var(--text-lg);
    color: var(--text-body);
  }
  .section__text:last-child {
    margin-bottom: 0;
  }
  /* Плашка контакта — тот же визуальный язык, что у ContactsPage (§9). */
  .contact {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-6);
    margin-top: var(--space-16);
    max-width: var(--container-prose);
    background: var(--surface-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-widget);
  }
  .contact__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex: none;
    border-radius: var(--radius-pill);
    background: var(--surface-page);
    color: var(--color-sea);
  }
  .contact__heading {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2);
  }
  .contact__line {
    margin: 0;
    color: var(--text-body);
    max-width: 60ch;
  }
  .contact__link {
    color: var(--link);
    font-weight: 600;
  }
  .contact__link:hover,
  .contact__link:focus-visible {
    color: var(--link-hover);
  }
</style>
