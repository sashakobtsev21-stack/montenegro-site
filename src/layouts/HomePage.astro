---
/**
 * HomePage (§8.4) — главная, направление «Полевой журнал».
 * Один компонент для ru (`/`) и uk (`/uk/`) — язык приходит пропсом, весь
 * текст из словарей (§12). Контента в коллекциях нет (R2) → честные пустые
 * состояния, без выдуманных статей/мест/цен (CLAUDE правило 4).
 *
 * Посыл — справочный и коллективный: места отбираются по высокому рейтингу и
 * сверяются с опытными путешественниками, гидами и местными жителями. Без
 * персональной личности автора.
 *
 * Состав: hero+поиск → витрина (золотая лента) + строка доверия → бэнд
 * «Услуги для жизни в Грузии» (CTA) → свежие материалы → о проекте → footer (в Base).
 */
import { getCollectionSafe } from '../loaders/getCollectionSafe';
import BaseLayout from './BaseLayout.astro';
import {
  t,
  ALL_SECTION_KEYS,
  sectionHref,
  articleHref,
  formatDate,
  type Lang,
  type SectionKey,
} from '../i18n';
import ShowcaseRail, { type ShowcaseItem } from '../components/ShowcaseRail.astro';
import SearchBox, { type SearchItem } from '../components/SearchBox.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Icon from '../components/Icon.astro';
import EmptyHint from '../components/EmptyHint.astro';
import { getImage } from 'astro:assets';
import heroGergeti from '../assets/hero/gergeti-kazbek-2.jpg';
import heroUshguli from '../assets/hero/ushguli.jpg';
import heroMestia from '../assets/hero/mestia-ushba.jpg';
import heroTbilisi from '../assets/hero/tbilisi-colorful.jpg';
import heroKakheti from '../assets/hero/kakheti-vineyards.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = t(lang);

const pageTitle = `${dict.siteName} — ${dict.tagline}`;
const description = dict.home.heroSubtitle;

/**
 * Hero-фон с ротацией: кадр меняется каждые 3 часа (по 3-часовому окну
 * времени, floor(now / 3ч) % N) — чистая статика, без бэкенда. Исходники —
 * Unsplash (бесплатная лицензия); атрибуция (автор · Unsplash) и ссылка на фото —
 * в credit под кадром, меняются вместе с фото. astro:assets даёт адаптивный
 * webp (responsive widths). LCP (§15): <img> рендерится без src, инлайн-скрипт
 * сразу за ним ставит srcset выбранного кадра (без двойной загрузки),
 * fetchpriority=high; <noscript> — дефолтный кадр для отключённого JS.
 */
// Hero — full-bleed фон со СКРИМОМ. Раньше упирался в 1280px webp: на широком
// десктопе кадр апскейлился до ~1920 и мылил. Чинится разрешением (битрейт под
// тёмным скримом вторичен), но жёсткий бюджет §15 (каждая картинка ≤200КБ, гейт qa)
// не даёт детальным кадрам влезть в 1600+ на webp. Поэтому AVIF (сжимает заметно
// плотнее) до 1600px + webp-фолбэк до 1280px для ~5% браузеров без AVIF (<picture>).
// `sizes="100vw"`: мобайл (70%+ трафика, §15) и Lighthouse-mobile берут 640/960/1280;
// 1600 уезжает только на десктоп. quality AVIF — per-image (q): детальный снежный
// Гергети жмём сильнее, мягкий градиент Кахетии — мягче; так каждый вариант ≤~175КБ.
const AVIF_WIDTHS = [640, 960, 1280, 1600];
const WEBP_WIDTHS = [640, 960, 1280];
const heroSources = [
  {
    img: heroGergeti,
    q: 40,
    credit: 'Deogyeon Hwang · Unsplash',
    href: 'https://unsplash.com/photos/vep3LTkwuwo',
    focus: '50% 50%',
  },
  {
    img: heroUshguli,
    q: 50,
    credit: 'Patrick Schneider · Unsplash',
    href: 'https://unsplash.com/photos/8bPJ0vagphw',
    focus: '50% 55%',
  },
  {
    img: heroMestia,
    q: 48,
    credit: 'Mike Swigunski · Unsplash',
    href: 'https://unsplash.com/photos/oqWb_tOK7ns',
    focus: '50% 50%',
  },
  {
    img: heroTbilisi,
    q: 52,
    credit: 'Inna Nasonova · Unsplash',
    href: 'https://unsplash.com/photos/VcbjEhgdR9A',
    focus: '50% 45%',
  },
  {
    img: heroKakheti,
    q: 62,
    credit: 'Giga Goriashvili · Unsplash',
    href: 'https://unsplash.com/photos/Lf__9L2SHVQ',
    focus: '50% 55%',
  },
];
const heroVariants = await Promise.all(
  heroSources.map(async (s) => {
    const [avif, webp] = await Promise.all([
      getImage({ src: s.img, width: 1600, widths: AVIF_WIDTHS, format: 'avif', quality: s.q }),
      // webp-фолбэк ≤1280px — держит каждый вариант ≤200КБ (§15) для браузеров без AVIF
      getImage({ src: s.img, width: 1280, widths: WEBP_WIDTHS, format: 'webp', quality: 64 }),
    ]);
    return {
      avifSrcset: avif.srcSet.attribute,
      webpSrcset: webp.srcSet.attribute,
      src: webp.src,
      focus: s.focus,
      href: s.href,
      credit: s.credit,
    };
  }),
);
const heroDefault = heroVariants[0];

/**
 * Индекс для клиентского поиска (§8.4): берём опубликованные статьи этого
 * языка. На R2 коллекция пуста → items = [] → SearchBox показывает корректное
 * пустое состояние. Никаких подделанных результатов.
 */
const articles = await getCollectionSafe(
  'articles',
  (entry) =>
    entry.data.lang === lang && entry.data.draft !== true && entry.data.demo !== true,
);
const searchItems: SearchItem[] = articles.map((entry) => ({
  title: entry.data.title,
  url: articleHref(lang, entry.data.category, entry.data.slug),
  section: dict.nav[entry.data.category as SectionKey] ?? entry.data.category,
}));

/**
 * Свежие материалы (§8.4): 6 самых новых статей этого языка — витрина на
 * главной с перелинковкой в разделы. Порядок: новее → старее (publishedAt
 * desc), тай-брейк по slug (детерминизм сборки).
 */
const freshCards = [...articles]
  .sort((a, b) => {
    const diff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
    return diff !== 0 ? diff : a.data.slug.localeCompare(b.data.slug);
  })
  .slice(0, 6)
  .map((entry) => ({
    key: entry.id,
    href: articleHref(lang, entry.data.category, entry.data.slug),
    title: entry.data.title,
    description: entry.data.description,
    cover: entry.data.cover,
    date: formatDate(entry.data.verifiedAt ?? entry.data.updatedAt, lang),
    verified: (entry.data.verifiedAt ? 'verified' : 'updated') as 'verified' | 'updated',
    verifiedPhoto: entry.data.verifiedPhoto,
  }));
const hasFresh = freshCards.length > 0;

/**
 * Блок «Новости» на главной (§8.4): свежие за 2 дня. Серверный фильтр — по дате
 * СБОРКИ; клиентский /js/news-freshness.js держит окно между сборками (до
 * ежедневного rebuild через Cloudflare Deploy Hook — подключим позже).
 */
const NEWS_HOME_WINDOW = 2;
const homeNews = articles
  .filter((entry) => entry.data.category === 'novosti')
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .filter((entry) => Math.floor((Date.now() - entry.data.publishedAt.getTime()) / 86400000) <= NEWS_HOME_WINDOW)
  .slice(0, 5)
  .map((entry) => ({
    href: articleHref(lang, 'novosti', entry.data.slug),
    title: entry.data.title,
    date: formatDate(entry.data.verifiedAt ?? entry.data.publishedAt, lang),
    iso: entry.data.publishedAt.toISOString().slice(0, 10),
  }));
const hasHomeNews = homeNews.length > 0;

/**
 * Витрина (§8.4/§16): золотая лента из ключевых материалов + одно открытое
 * рекламное место (инвентарь под продажу). Подборка курируется по слугам, но
 * обложка/заголовок берутся из коллекции — реальные данные, не выдумываем
 * (CLAUDE правило 4). Маршруты живут в отдельной коллекции `routes`.
 */
const routes = await getCollectionSafe(
  'routes',
  (entry) => entry.data.lang === lang && entry.data.draft !== true && entry.data.demo !== true,
);
const showcaseRestaurants = await getCollectionSafe(
  'restaurants',
  (entry) => entry.data.lang === lang && entry.data.draft !== true,
);
// Заведения перемешаны со статьями/маршрутами (не подряд) — решение владельца.
const showcasePicks = [
  { kind: 'article', category: 'goroda', slug: 'tbilisi', kicker: 'city' },
  { kind: 'restaurant', slug: 'guinness-by-sinori', edaSlug: 'gde-poest-batumi', kicker: 'food' },
  { kind: 'route', slug: 'tbilisi-kazbegi-2-dnya', kicker: 'route' },
  // Teatro — статья «Развлечения» как place-карточка (поповер: адрес/часы/карта/сайт)
  // со знаком качества; всё по запросу владельца.
  {
    kind: 'article',
    category: 'razvlecheniya',
    slug: 'teatro-batumi',
    kicker: 'nightlife',
    quality: true,
    place: true,
    cardTitle: 'Teatro',
    mapUrl: 'https://maps.app.goo.gl/qMh9Kj2rMURoVfLy5',
  },
  { kind: 'article', category: 'dostoprimechatelnosti', slug: 'vardzia', kicker: 'sight' },
  { kind: 'restaurant', slug: 'sushiman-batumi', edaSlug: 'gde-poest-batumi', kicker: 'food' },
  { kind: 'article', category: 'eda', slug: 'chto-poprobovat', kicker: 'food' },
  { kind: 'route', slug: 'gomismta-iz-batumi', kicker: 'route' },
  { kind: 'article', category: 'goroda', slug: 'batumi', kicker: 'city' },
] as const;
const showcaseItems: ShowcaseItem[] = [];
for (const pick of showcasePicks) {
  if (pick.kind === 'restaurant') {
    const r = showcaseRestaurants.find((x) => x.data.slug === pick.slug);
    if (!r || !r.data.cover) continue;
    showcaseItems.push({
      href: `${sectionHref(lang, 'eda')}${pick.edaSlug}/#r-${r.data.slug}`,
      title: r.data.name,
      cover: r.data.cover,
      kicker: dict.home.showcase.kickers[pick.kicker],
      city: r.data.city,
      place: true,
      quality: r.data.qualityMark === true,
      subtitle: r.data.cuisine,
      hours: r.data.hours,
      info: r.data.summary,
      address: r.data.geo.address,
      mapUrl: r.data.mapUrl,
      website: r.data.website,
      instagram: r.data.instagram,
      photos: [
        { src: r.data.cover.src, alt: r.data.cover.alt, credit: r.data.coverCredit },
        ...(r.data.gallery ?? []).map((g) => ({ src: g.src, alt: g.alt, credit: g.credit })),
      ],
    });
    continue;
  }
  const entry =
    pick.kind === 'route'
      ? routes.find((r) => r.data.slug === pick.slug)
      : articles.find((a) => a.data.category === pick.category && a.data.slug === pick.slug);
  if (!entry || !entry.data.cover) continue;
  const category = pick.kind === 'route' ? 'marshruty' : pick.category;
  const p = pick as {
    quality?: boolean;
    city?: string;
    place?: boolean;
    cardTitle?: string;
    mapUrl?: string;
  };
  if (p.place) {
    // Статья-место (Teatro): рендерим как place-карточку витрины с поповером
    // (адрес/часы/карта/сайт) и каруселью фото — как у заведений.
    const batumiCity = lang === 'uk' ? 'Батумі' : lang === 'en' ? 'Batumi' : 'Батуми';
    showcaseItems.push({
      href: articleHref(lang, category, entry.data.slug),
      title: p.cardTitle ?? entry.data.title,
      cover: entry.data.cover,
      kicker: dict.home.showcase.kickers[pick.kicker],
      city: p.city ?? batumiCity,
      place: true,
      quality: p.quality === true,
      hours: entry.data.visit?.hours,
      info: entry.data.description,
      address: entry.data.geo?.address,
      mapUrl: p.mapUrl,
      website: entry.data.website,
      instagram: entry.data.instagram,
      photos: [
        { src: entry.data.cover.src, alt: entry.data.cover.alt },
        ...(entry.data.gallery ?? []).map((g: { src: string; alt: string; credit?: string }) => ({
          src: g.src,
          alt: g.alt,
          credit: g.credit,
        })),
      ],
    });
    continue;
  }
  showcaseItems.push({
    href: articleHref(lang, category, entry.data.slug),
    title: entry.data.title,
    cover: entry.data.cover,
    kicker: dict.home.showcase.kickers[pick.kicker],
    // Знак качества на карточке-статье — только по запросу владельца (Teatro).
    quality: p.quality === true,
    // Опознавательный пин-чип города (для заведений). Задаётся явно у pick:
    // напр. { kind:'article', category:'eda', slug:'…', kicker:'food', city:'Тбилиси' }.
    // У текущих контентных карточек (города/маршруты) не задан → чип не рисуется.
    city: p.city,
  });
}
// Открытое рекламное место («Разместите своё заведение») убрано с витрины по
// решению владельца 2026-06-17. Поддержка ad-слота в ShowcaseRail оставлена
// спящей — чтобы вернуть, снова добавить сюда showcaseItems.push({ ad:true, ... }).

---

<BaseLayout title={pageTitle} description={description} lang={lang}>
  {
    /* 1. Hero — текстовый, без тяжёлой картинки (LCP, §15).
       data-hero-stagger: мягкий вход H1→подзаголовок→поиск (≤450мс), только
       при .js-anim и разрешённом движении (FOUC-safe, см. global.css). */
  }
  <section class="hero">
    <picture>
      <source id="heroAvif" type="image/avif" srcset={heroDefault.avifSrcset} sizes="100vw" />
      <img
        class="hero__bg"
        id="heroBg"
        src={heroDefault.src}
        srcset={heroDefault.webpSrcset}
        sizes="100vw"
        alt=""
        decoding="async"
        fetchpriority="high"
        style={`object-position:${heroDefault.focus}`}
      />
    </picture>
    <script
      is:inline
      type="application/json"
      id="hero-variants"
      set:html={JSON.stringify({
        variants: heroVariants,
        periodMs: 3 * 60 * 60 * 1000,
        prefix: dict.home.photoPrefix,
      })}
    />
    <script is:inline src="/js/hero-rotate.js"></script>
    <div class="hero__scrim"></div>
    <div class="container hero__content" data-hero-stagger>
      <h1 class="hero__title">{dict.home.heroTitle}</h1>
      <p class="hero__subtitle">{dict.home.heroSubtitle}</p>
      <SearchBox lang={lang} items={searchItems} />
    </div>
    <a
      class="hero__credit"
      id="heroCredit"
      href={heroDefault.href}
      target="_blank"
      rel="noopener nofollow"
    >
      {dict.home.photoPrefix}: {heroDefault.credit}
    </a>
  </section>

  {/* Новости — свежие за 2 дня; блок скрывается, если свежего нет (§8.4). */}
  {
    hasHomeNews && (
      <section class="block news-strip" data-news-section data-reveal>
        <div class="container" data-news-feed data-news-window="2">
          <div class="news-strip__head">
            <h2 class="block__heading">{dict.newsFeed.recentHeading}</h2>
            <a class="news-strip__all" href={sectionHref(lang, 'novosti')}>
              {dict.newsFeed.all}
              <Icon name="arrow-right" size={16} />
            </a>
          </div>
          <ul class="news-strip__list">
            {homeNews.map((n) => (
              <li class="news-strip__item" data-news-item data-published={n.iso}>
                <time class="news-strip__date">{n.date}</time>
                <a class="news-strip__link" href={n.href}>
                  {n.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  {/* 2. Витрина — золотая лента партнёров/материалов (заменяет «С чего начать»). */}
  <section class="block block--showcase">
    <div class="container">
      <h2 class="block__heading" data-reveal>{dict.home.showcase.heading}</h2>
      <p class="showcase-lead" data-reveal>
        {dict.home.showcase.lead}{' '}
        <span class="showcase-lead__partner">{dict.home.showcase.partnerNote}</span>
      </p>
      <ShowcaseRail lang={lang} items={showcaseItems} label={dict.home.showcase.aria} />
      <p class="trust-line" data-reveal>
        {dict.home.trustLead}{' '}
        <a class="trust-line__link" href={sectionHref(lang, 'o-sajte')}>
          {dict.home.about.link}
          <Icon name="arrow-right" size={16} />
        </a>
      </p>
    </div>
  </section>

  {/* 2b. Разделы путеводителя — on-page входы во ВСЕ разделы, включая «денежные»
       (Транспорт/Аренда/Страховки/Новости), иначе зарытые в ☰/футер (аудит NAV-2). */}
  <section class="block block--sections">
    <div class="container">
      <h2 class="block__heading" data-reveal>{dict.home.sectionsHeading}</h2>
      <ul class="home-sections" data-reveal>
        {ALL_SECTION_KEYS.map((key) => (
          <li>
            <a class="home-section" href={sectionHref(lang, key)}>
              <span>{dict.nav[key]}</span>
              <Icon name="arrow-right" size={16} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* 3. Услуги для жизни в Грузии — заметный CTA-бэнд (продаваемый инвентарь, §16). */}
  <section class="services-band">
    <div class="container services-band__inner" data-reveal>
      <div class="services-band__text">
        <h2 class="services-band__title">{dict.relocation.uslugi.heading}</h2>
        <p class="services-band__lead">{dict.relocation.uslugi.text}</p>
      </div>
      <a class="services-band__cta" href={`${sectionHref(lang, 'relokatsiya')}uslugi/`}>
        {dict.relocation.uslugi.cta}
        <Icon name="arrow-right" size={18} />
      </a>
    </div>
  </section>

  {/* 4. Свежие материалы — витрина 6 последних статей (или честное пустое состояние) */}
  <section class="block">
    <div class="container">
      <h2 class="block__heading" data-reveal>{dict.home.freshHeading}</h2>
      {
        hasFresh ? (
          <div class="fresh-grid">
            {freshCards.map((card) => (
              <ArticleCard
                lang={lang}
                href={card.href}
                title={card.title}
                description={card.description}
                cover={card.cover}
                date={card.date}
                verified={card.verified}
                verifiedPhoto={card.verifiedPhoto}
                meta={[]}
              />
            ))}
          </div>
        ) : (
          <div data-reveal><EmptyHint text={dict.home.freshEmpty} /></div>
        )
      }
    </div>
  </section>

  {/* 6. О проекте — нейтральный блок со ссылкой на /o-sajte/ */}
  <section class="block">
    <div class="container about">
      <h2 class="block__heading" data-reveal>{dict.home.about.heading}</h2>
      <p class="about__text" data-reveal>{dict.home.about.text}</p>
      <a class="about__link" href={sectionHref(lang, 'o-sajte')} data-reveal>
        {dict.home.about.link}
        <Icon name="arrow-right" size={18} />
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-content);
    margin: 0 auto;
    padding-inline: var(--space-4);
  }

  /* Hero — фотофон Грузии (Гергети+Казбек) + тёмный скрим, светлый текст.
     Картинка — LCP-элемент: astro:assets даёт адаптивные avif/webp, грузим
     eager+high. Скрим обеспечивает контраст ≥4.5 (§6). Параллакса нет → §15. */
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: clamp(440px, 72vh, 660px);
    overflow: hidden;
    /* Тёмный фон-заглушка под фото (до загрузки / без JS) — светлый текст читаем. */
    background-color: var(--color-slate);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
  }
  /*
   * Скрим направленный: тёмный слева (под текстом) → прозрачный справа, чтобы
   * фото оставалось ярким (правка владельца 2026-06-17). Плюс лёгкая подложка
   * снизу под кредит. На мобайле текст шире → вертикальный градиент (легче, чем
   * раньше: 10/42/60 вместо 20/44/74), читаемость держит усиленная тень текста.
   */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        90deg,
        var(--hero-scrim-text) 0%,
        var(--hero-scrim-text-2) 34%,
        var(--hero-scrim-text-3) 60%,
        transparent 78%
      ),
      linear-gradient(0deg, var(--hero-scrim-base) 0%, transparent 30%);
  }
  @media (max-width: 768px) {
    .hero__scrim {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-slate) 20%, transparent) 0%,
        color-mix(in srgb, var(--color-slate) 50%, transparent) 48%,
        color-mix(in srgb, var(--color-slate) 66%, transparent) 100%
      );
    }
  }
