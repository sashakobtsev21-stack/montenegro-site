---
/**
 * Кастомная 404 (§7; аудит 2026-06-17 — закрыта «слепая зона»). Cloudflare отдаёт
 * один 404.html на любой ненайденный путь, поэтому рендерим на языке по умолчанию
 * (en). Полная навигация и переключатель языка — в шапке (Header из BaseLayout),
 * так что ru/uk-читатель сразу переключится на свой язык/раздел. noindex.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, sectionHref, DEFAULT_LANG } from '../i18n';
import Icon from '../components/Icon.astro';

const lang = DEFAULT_LANG;
const dict = t(lang);
const nf = dict.notFound;
/**
 * На 404 переключатель языка и hreflang ограничиваем одним языком (en): зеркальных
 * /ru/404, /uk/404 не существует — иначе шапка/hreflang дадут битые ссылки. Вместо
 * свитчера даём в теле явные входы на главную всех языков (эти страницы существуют).
 */
const homes = [
  { href: sectionHref('en', 'home'), label: t('en').notFound.home },
  { href: sectionHref('ru', 'home'), label: t('ru').notFound.home },
  { href: sectionHref('uk', 'home'), label: t('uk').notFound.home },
];
---

<BaseLayout title={`404 — ${dict.siteName}`} description={nf.text} lang={lang} utility>
  <section class="nf">
    <div class="container">
      <p class="nf__code">404</p>
      <h1 class="nf__heading">{nf.heading}</h1>
      <p class="nf__text">{nf.text}</p>
      <div class="nf__homes">
        {
          homes.map((h, i) => (
            <a class:list={['nf__home', { 'nf__home--alt': i !== 0 }]} href={h.href}>
              {i === 0 && <Icon name="arrow-right" size={18} />}
              <span>{h.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-content);
    margin: 0 auto;
    padding-inline: var(--space-4);
  }
  .nf {
    padding-block: var(--space-24);
    text-align: center;
  }
  .nf__code {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-gold-deep);
    margin: 0 0 var(--space-2);
    letter-spacing: 0.05em;
  }
  .nf__heading {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-4);
  }
  .nf__text {
    max-width: 42rem;
    margin: 0 auto var(--space-8);
    font-size: var(--text-lg);
    color: var(--text-body);
  }
  .nf__homes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
  .nf__home {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--cta-bg);
    color: var(--text-on-cta);
    border: 1px solid transparent;
    border-radius: var(--radius-card);
    text-decoration: none;
    font-weight: 600;
    transition: background var(--dur) var(--ease-standard);
  }
  .nf__home:hover,
  .nf__home:focus-visible {
    background: var(--cta-bg-hover);
  }
  /* Вторичные (ru/uk) — контурные, чтобы основной CTA (en) был акцентом. */
  .nf__home--alt {
    background: var(--surface-card);
    color: var(--text-body);
    border-color: var(--border-card);
    font-weight: 500;
  }
  .nf__home--alt:hover,
  .nf__home--alt:focus-visible {
    background: var(--surface-hover);
  }
  .nf__home :global(svg) {
    flex: none;
  }
</style>
