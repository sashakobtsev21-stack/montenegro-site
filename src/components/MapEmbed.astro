---
/**
 * MapEmbed (§9, §8.2) — Leaflet + OpenStreetMap, СТРОГО lazy.
 *
 * Контракт перфа (§15): ни Leaflet-JS (≈147 КБ), ни его CSS НЕ попадают в
 * начальный бандл страницы и НЕ грузятся, пока контейнер не появился во
 * вьюпорте ИЛИ пользователь не нажал «Показать карту». Этот компонент рендерит
 * только лёгкий плейсхолдер с зарезервированной высотой (ноль CLS, §15) и
 * JSON-остров с остановками. Подгрузку Leaflet и инициализацию делает внешний
 * vanilla-модуль /js/map-init.js (script-src 'self', §18 — без inline, без CDN;
 * Leaflet self-host в /vendor/leaflet/, §13).
 *
 * Маркеры — из `stops[]` (frontmatter §11), передаются как JSON-остров в
 * <script type="application/json">. Тайлы OSM (*.tile.openstreetmap.org) уже
 * разрешены в _headers CSP (§18). Атрибуция OSM обязательна по лицензии.
 *
 * Доступность (§15): контейнер — role="region" с aria-label; кнопка «показать
 * карту» фокусируема и работает с клавиатуры; reduced-motion уважается (карта
 * без анимаций zoom — это решает map-init.js).
 */
import { t, type Lang } from '../i18n';
import Icon from './Icon.astro';

export interface MapStop {
  name: string;
  coord: [number, number];
}

interface Props {
  lang: Lang;
  /**
   * Точки на карте. Маршрут передаёт массив остановок (рисуется линия между
   * ними); статья о месте — массив из ОДНОГО маркера (карта центрируется на
   * точке, без линии). Обобщение §8.1/§8.2: один компонент на оба случая —
   * различие («точка» vs «маршрут») решает только число элементов, а это
   * уже учитывает map-init.js (setView для одной точки, fitBounds+polyline
   * для нескольких).
   */
  stops: MapStop[];
  /**
   * Набор подписей блока карты. По умолчанию — маршрутный («Карта маршрута»);
   * 'place' даёт нейтральные подписи для статьи о месте («На карте»). Строки —
   * из словаря (§12), не хардкод.
   */
  variant?: 'route' | 'place';
  /** Уникальный id контейнера (на странице может быть несколько карт). */
  id?: string;
  /**
   * Реальная дорожная геометрия маршрута — полилиния [[lat,lng],…], запечённая
   * на сборке (scripts/build-route-geometry.mjs → src/data/route-geometry.json).
   * Рисуется поверх Leaflet ВМЕСТО прямых линий между стопами. Опционально:
   * нет геометрии → фолбэк на прямые между остановками (старое поведение).
   */
  geometry?: [number, number][];
}

const { lang, stops, variant = 'route', id = 'route-map', geometry } = Astro.props;
const dict = t(lang);
const r = dict.route;
const m = dict.map;

/**
 * Подписи блока берём из общего словаря карты (`dict.map`) — он покрывает и
 * место, и маршрут; маршрутный заголовок переопределяем route-строкой, чтобы
 * не плодить дублей. Атрибуция OSM и тексты ошибок/кнопки — общие.
 */
const labels =
  variant === 'place'
    ? {
        heading: m.placeHeading,
        aria: m.placeAria,
        hint: m.placeHint,
      }
    : {
        heading: r.mapHeading,
        aria: r.mapAria,
        hint: r.mapHint,
      };

/** Данные для JSON-острова: только то, что нужно карте (имя + координата). */
const mapData = {
  attribution: m.attribution,
  stops: stops.map((s) => ({ name: s.name, coord: s.coord })),
  ...(geometry && geometry.length > 1 ? { geometry } : {}),
};
const jsonId = `${id}-data`;
const headingId = `${id}-heading`;
---

{
  stops.length > 0 && (
    <section class="map" aria-labelledby={headingId}>
      <h2 id={headingId} class="map__heading">
        {labels.heading}
      </h2>

      {/* JSON-остров с точками — читает /js/map-init.js при подгрузке. */}
      <script is:inline id={jsonId} type="application/json" set:html={JSON.stringify(mapData)} />

      <div
        class="map__frame"
        id={id}
        data-map
        data-map-data={jsonId}
        role="region"
        aria-label={labels.aria}
      >
        {/* Плейсхолдер до загрузки Leaflet: высота зарезервирована → 0 CLS. */}
        <div class="map__placeholder" data-map-placeholder>
          <span class="map__placeholder-icon">
            <Icon name="map-pin" size={32} />
          </span>
          <button type="button" class="map__btn" data-map-show>
            {m.show}
          </button>
          <p class="map__hint">{labels.hint}</p>
          <p class="map__error" data-map-error hidden>
            {m.error}
          </p>
        </div>
      </div>
    </section>
  )
}

{
  /* Инициализатор карты — внешний vanilla-модуль (self, без inline §18).
    No-op, если на странице нет [data-map]; Leaflet тянет только по
    IntersectionObserver/клику (§8.2). Один модуль обслуживает все карты. */
}
<script is:inline type="module" src="/js/map-init.js"></script>

<style>
  .map {
    margin-block: var(--space-8) var(--space-12);
    max-width: var(--container-prose);
  }
  .map__heading {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-6);
  }
  /*
   * Зарезервированная высота — главный приём против CLS (§15): плейсхолдер и
   * будущая карта занимают одну и ту же высоту, ничего не «прыгает» при загрузке.
   */
  .map__frame {
    position: relative;
    /* Свой stacking-контекст (z-index:0) запирает внутренние z-index Leaflet
       (до ~1000) внутри рамки → карта не наезжает на sticky-шапку (z-50). */
    z-index: 0;
    width: 100%;
    height: 380px;
    border: 1px solid var(--border-card);
    border-radius: var(--radius-widget);
    overflow: hidden;
    background: var(--surface-card);
  }
  @media (min-width: 768px) {
    .map__frame {
      height: 440px;
    }
  }

  .map__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-6);
    text-align: center;
    /* лёгкий фон без тяжёлых картинок — камень-поверхность */
    background: var(--surface-page);
  }
  .map__placeholder-icon {
    display: inline-flex;
    color: var(--color-wine);
  }
  .map__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-6);
    font: inherit;
    font-weight: 600;
    color: var(--text-on-cta);
    background: var(--cta-bg);
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition:
      background-color var(--dur) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .map__btn:hover {
    background: var(--cta-bg-hover);
  }
  .map__btn:active {
    transform: scale(var(--press-scale));
  }
  .map__hint {
    margin: 0;
    max-width: 44ch;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .map__error {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-wine);
    font-weight: 500;
  }

  /*
   * Когда map-init.js инициализировал Leaflet, он ставит на .map__frame класс
   * is-loaded → прячем плейсхолдер. Карту рисует Leaflet внутри того же
   * контейнера. Размер контейнера не меняется → ноль CLS.
   */
  .map__frame.is-loaded .map__placeholder {
    display: none;
  }

  /* Leaflet-контейнер должен занять всю зарезервированную высоту. */
  .map__frame :global(.leaflet-container) {
    width: 100%;
    height: 100%;
    background: var(--surface-card);
    font: inherit;
  }
  /* Тонкая подгонка атрибуции/контролов под токены (без хардкода hex). */
  .map__frame :global(.leaflet-control-attribution) {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .map__btn {
      transition: none;
    }
  }
</style>
